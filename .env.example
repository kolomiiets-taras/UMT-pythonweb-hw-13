# Database
DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/contacts

# App
APP_HOST=0.0.0.0
APP_PORT=8000
BASE_URL=http://localhost:8000

# JWT
JWT_SECRET=change-me-super-secret-key-min-32-bytes-long-please
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
EMAIL_TOKEN_EXPIRE_HOURS=24

# Mail (SMTP)
MAIL_USERNAME=example@meta.ua
MAIL_PASSWORD=secret
MAIL_FROM=example@meta.ua
MAIL_PORT=465
MAIL_SERVER=smtp.meta.ua
MAIL_FROM_NAME=Contacts API

# Cloudinary
CLD_NAME=cloud-name
CLD_API_KEY=0000000000
CLD_API_SECRET=secret
